# Comma-separated host allowlist. Use '*' to capture all traffic (default).
CAPTURE_DOMAINS=*

# Where logs are written.
LOG_DIR=logs

# Capture response payloads as well.
SAVE_RESPONSES=true

# Redact Authorization header value in logs.
REDACT_AUTH=true

# Max bytes to persist per body.
MAX_BODY_BYTES=2097152

# Web UI host/port (local only by default).
WEBUI_HOST=127.0.0.1
WEBUI_PORT=8765
